# Port configuration (dynamic port binding for Render)
PORT=5000

# Database URL: Supabase PostgreSQL Connection String (Transaction mode / Session mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# Supabase Auth Configuration (For Email OTP authentication)
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authorized Emails (Comma-separated list of emails permitted to use the system)
ALLOWED_EMAILS=authorized1@example.com,authorized2@example.com
